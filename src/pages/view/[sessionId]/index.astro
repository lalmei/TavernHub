---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { VttBoard } from '@/components/VttBoard';
import { ensureWsHub } from '@/lib/wsHub';

const { sessionId } = Astro.params;
ensureWsHub();
---

<BaseLayout title={`Player View ${sessionId}`}>
  <VttBoard client:load sessionId={sessionId!} mode="viewer" />
</BaseLayout>
